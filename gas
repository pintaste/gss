    print(f'export GROK_HOME="{home}"')


def cmd_exec(args: argparse.Namespace) -> None:
    """Run a command with GROK_HOME pointed at an isolated account dir."""
    ensure_layout()
    seq = read_sequence()
    num = resolve_account_identifier(args.identifier, seq)
    if num is None:
        die(f"account '{args.identifier}' not found")

    cmd = list(args.command or [])
    if cmd and cmd[0] == "--":
        cmd = cmd[1:]
    if not cmd:
        die("usage: gas exec <account> [--dir PATH] -- <command> [args...]")

    dest = Path(args.dest).expanduser() if args.dest else None
    if DRY_RUN:
        email = seq["accounts"][str(num)].get("email")
        info(f"[DRY RUN] Would materialize Account-{num} ({email}) and run: {' '.join(cmd)}")
        return

    home = materialize_account_home(num, dest)
    env = os.environ.copy()
    env["GROK_HOME"] = str(home)
    # Avoid gas test override leaking into child
    env.pop("GROK_DIR", None)
    if not SILENT:
        print(f"{DIM}GROK_HOME={home}{RESET}", file=sys.stderr)
    try:
        raise SystemExit(subprocess.call(cmd, env=env))
    except FileNotFoundError:
        die(f"command not found: {cmd[0]}")


