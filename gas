def build_parser() -> argparse.ArgumentParser:
    p = argparse.ArgumentParser(
        prog="gas",
        description="Multi-Account Switcher for Grok CLI (ccs-style)",
        formatter_class=argparse.RawDescriptionHelpFormatter,
        epilog="""
examples:
  gas add                         # capture current login
  gas ls / gas sw / gas to 2
  gas -n sw                       # dry-run
  gas profile 1 work
  gas dir ~/proj 1 && gas auto
  gas exec 2 -- grok -p "hi"      # isolated via GROK_HOME
  gas config-dir 2                # print export GROK_HOME=...
  gas check / status / stats

  # second account:
  gas add && grok logout && grok login && gas add && gas sw

environment:
  GSS_HOME / GAS_HOME   store dir (default ~/.grok-switch)
  GROK_HOME / GROK_DIR  live Grok config (default ~/.grok)
  GAS_SILENT=1          quiet mode (for scripts)
  NO_COLOR              disable colors
""",
    )
    p.add_argument("-V", "--version", action="version", version=f"gas {__version__}")
    p.add_argument(
        "-n",
        "--dry-run",
        action="store_true",
        help="show what would happen without making changes",
    )

    sub = p.add_subparsers(dest="cmd")

    sub.add_parser("add", help="add/update current login as managed account")
    sub.add_parser("ls", aliases=["list"], help="list managed accounts")
    sub.add_parser("sw", help="rotate to next account in sequence")
    sp = sub.add_parser("to", help="switch to account by number, email, or profile")
    sp.add_argument("identifier")

    sp = sub.add_parser("profile", help="set friendly profile name")
    sp.add_argument("identifier")
    sp.add_argument("name")

    sp = sub.add_parser("rm", aliases=["remove", "delete"], help="remove managed account")
    sp.add_argument("identifier")
    sp.add_argument("-y", "--yes", action="store_true")

    sp = sub.add_parser("dir", help="map directory → account")
    sp.add_argument("parts", nargs="+", metavar="ARG", help="[directory] <account>")

    sub.add_parser("auto", help="switch based on cwd mapping")

    sp = sub.add_parser("exec", help="run command as account (isolated GROK_HOME)")
    sp.add_argument("identifier")
    sp.add_argument("--dir", dest="dest", help="custom isolated dir path")
    sp.add_argument(
        "command",
        nargs=argparse.REMAINDER,
        help="command after optional --",
    )

    sp = sub.add_parser("config-dir", help="materialize isolated GROK_HOME and print export")
    sp.add_argument("identifier")
    sp.add_argument("dest", nargs="?", help="optional destination path")

    sub.add_parser("check", help="verify backup integrity")
    sub.add_parser("status", aliases=["current"], help="current account + token expiry")
    sub.add_parser("stats", help="per-account usage statistics")
    sub.add_parser("whoami", help="print active email")
    sub.add_parser("version", help="print version")
    sub.add_parser("help", help="show help")

    sp = sub.add_parser("save", help="(legacy) add + optional profile")
    sp.add_argument("name", nargs="?")
    sp = sub.add_parser("use", aliases=["switch"], help="(legacy) → to")
    sp.add_argument("name")
    sp = sub.add_parser("rename", help="(legacy) rename profile")
    sp.add_argument("old")
    sp.add_argument("new")

    return p


def main(argv: list | None = None) -> None:
    global DRY_RUN
    parser = build_parser()
    args = parser.parse_args(argv)
    DRY_RUN = bool(getattr(args, "dry_run", False))

    cmd = args.cmd
    if cmd is None:
        cmd_ls(argparse.Namespace())
        return
    if cmd == "help":
        cmd_help(parser)
        return

    handlers: dict[str, Any] = {
        "add": cmd_add,
        "ls": cmd_ls,
        "list": cmd_ls,
        "sw": cmd_sw,
        "to": cmd_to,
        "profile": cmd_profile,
        "rm": cmd_rm,
        "remove": cmd_rm,
        "delete": cmd_rm,
        "dir": cmd_dir,
        "auto": cmd_auto,
        "exec": cmd_exec,
        "config-dir": cmd_config_dir,
        "check": cmd_check,
        "status": cmd_status,
        "current": cmd_status,
        "stats": cmd_stats,
        "whoami": cmd_whoami,
        "version": cmd_version,
        "save": cmd_save_legacy,
        "use": cmd_use_legacy,
        "switch": cmd_use_legacy,
        "rename": cmd_rename_legacy,
    }
    handler = handlers.get(cmd)
    if not handler:
        parser.print_help()
        raise SystemExit(2)
    handler(args)


if __name__ == "__main__":
    main()
